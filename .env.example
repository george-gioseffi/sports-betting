APP_ENV=local
DATA_DIR=./data
WAREHOUSE_PATH=./data/warehouse.duckdb
INITIAL_BANKROLL=10000
DEFAULT_SEED=42

# --- bet_audit settings ---
# Search provider: off | csv | mock
SEARCH_PROVIDER=off
SEARCH_DATA_FILE=

# LLM mode: off | assisted | review_all_suspects | dual_review
LLM_MODE=off
# LLM provider: openai | anthropic | dual
LLM_PROVIDER=openai
# API keys (leave empty to disable)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Max LLM calls per audit run
MAX_LLM_CALLS=200
# Minimum confidence to accept LLM classification
MIN_CONFIDENCE=0.6
